<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ scenario.name }} — DPU Scenario Viewer</title>
<style>
/* ========== Reset & Base ========== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
body {
  font-family: 'Inter', system-ui, sans-serif;
  background: #0f0f14;
  color: #e0e0e0;
  overflow: hidden;
  height: 100vh;
}

/* ========== Layout ========== */
#app-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}
#header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 24px;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  flex-shrink: 0;
}
#header h1 {
  font-size: 18px;
  font-weight: 700;
  background: linear-gradient(90deg, #a78bfa, #818cf8);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
#header .desc {
  font-size: 12px;
  color: #888;
  margin-left: 16px;
}
#header .back-link {
  font-size: 13px;
  color: #818cf8;
  text-decoration: none;
}
#header .back-link:hover { text-decoration: underline; }

#main-area {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ========== Canvas ========== */
#canvas {
  flex: 1;
  position: relative;
  background: #12121a;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
#canvas svg {
  /* sized by JS resizeCanvas() */
}

/* ========== Side Panel ========== */
#side-panel {
  width: 260px;
  background: #1a1a2e;
  border-left: 1px solid rgba(255,255,255,0.08);
  padding: 20px 16px;
  overflow-y: auto;
  flex-shrink: 0;
}
#side-panel h3 {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #a78bfa;
  margin-bottom: 12px;
}
.info-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 24px;
  font-size: 12px;
}
.info-table th {
  text-align: left;
  padding: 6px 8px;
  color: #888;
  font-weight: 500;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.info-table td {
  padding: 6px 8px;
  color: #e0e0e0;
  font-weight: 600;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  font-size: 12px;
}
.legend-swatch {
  width: 20px;
  height: 14px;
  border-radius: 3px;
  border: 1px solid rgba(255,255,255,0.15);
  flex-shrink: 0;
}
.legend-swatch.hatched {
  background-image: repeating-linear-gradient(
    45deg, transparent, transparent 3px,
    rgba(0,0,0,0.3) 3px, rgba(0,0,0,0.3) 6px
  );
}
.display-info {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.display-badge {
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  background: rgba(129, 140, 248, 0.15);
  color: #818cf8;
  border: 1px solid rgba(129, 140, 248, 0.3);
}

/* ========== Bottom Table ========== */
#bottom-panel {
  flex-shrink: 0;
  background: #16162a;
  border-top: 1px solid rgba(255,255,255,0.08);
  max-height: 35vh;
  overflow-y: auto;
}
#layer-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
#layer-table thead {
  position: sticky;
  top: 0;
  z-index: 10;
}
#layer-table th {
  padding: 10px 14px;
  text-align: left;
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: #a78bfa;
  background: #1a1a36;
  border-bottom: 2px solid rgba(167, 139, 250, 0.2);
}
#layer-table td {
  padding: 8px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  transition: background 0.15s;
}
#layer-table tr:hover td {
  background: rgba(129, 140, 248, 0.06);
}
#layer-table .fmt-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
}
#layer-table .fmt-yuv { background: rgba(255, 183, 77, 0.2); color: #FFB74D; }
#layer-table .fmt-argb { background: rgba(129, 199, 132, 0.2); color: #81C784; }
#layer-table .comp-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
}
#layer-table .comp-sbwc { background: rgba(239,83,80,0.15); color: #EF5350; }
#layer-table .comp-sajc { background: rgba(66,165,245,0.15); color: #42A5F5; }
#layer-table .comp-none { background: rgba(255,255,255,0.06); color: #888; }
#layer-table .bw-val { font-variant-numeric: tabular-nums; }
#layer-table .bw-compressed { color: #81C784; font-weight: 600; }

/* ========== SVG Diagram Nodes ========== */
.node-group { cursor: pointer; }
.node-rect { rx: 8; ry: 8; }
.node-label {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  text-anchor: middle;
  dominant-baseline: central;
  pointer-events: none;
}
.node-sublabel {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 400;
  text-anchor: middle;
  dominant-baseline: central;
  fill: #666;
  pointer-events: none;
}
.port-rect { rx: 3; ry: 3; }
.port-label {
  font-family: 'Inter', sans-serif;
  font-size: 8px;
  font-weight: 500;
  text-anchor: middle;
  dominant-baseline: central;
  pointer-events: none;
}
/* Buffer hatching pattern */
.buffer-hatch {
  rx: 6; ry: 6;
  opacity: 0.25;
}
/* Edge label background */
.edge-label-bg {
  rx: 4; ry: 4;
  fill: #1a1a2e;
  fill-opacity: 0.9;
  stroke: rgba(255,255,255,0.1);
  stroke-width: 0.5;
}
.edge-label-text {
  font-family: 'Inter', sans-serif;
  font-size: 9px;
  font-weight: 500;
  text-anchor: middle;
  dominant-baseline: central;
  pointer-events: none;
}
/* Edge hover highlight */
.edge-path { transition: stroke-width 0.15s; }
.edge-path:hover { stroke-width: 3; }

/* ========== Tooltip ========== */
#tooltip {
  display: none;
  position: absolute;
  background: #1e1e3a;
  border: 1px solid rgba(167,139,250,0.3);
  border-radius: 8px;
  padding: 12px 16px;
  font-size: 12px;
  color: #e0e0e0;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  z-index: 1000;
  max-width: 300px;
  pointer-events: none;
}
#tooltip .tip-title { font-weight: 700; color: #a78bfa; margin-bottom: 6px; }
#tooltip .tip-row { display: flex; justify-content: space-between; gap: 16px; padding: 2px 0; }
#tooltip .tip-key { color: #888; }
#tooltip .tip-val { font-weight: 600; }

/* Scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(167,139,250,0.3); border-radius: 3px; }
</style>
</head>
<body>

<div id="app-container">
  <!-- Header -->
  <div id="header">
    <div style="display:flex;align-items:baseline;">
      <h1>{{ scenario.name }}</h1>
      <span class="desc">{{ scenario.description }}</span>
    </div>
    <a class="back-link" href="../index.html">← {{ project_name }}</a>
  </div>

  <div id="main-area">
    <!-- Canvas -->
    <div id="canvas">
      <svg id="diagram" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Hatching pattern for compressed buffers -->
          <pattern id="hatch-yuv" patternUnits="userSpaceOnUse" width="8" height="8" patternTransform="rotate(45)">
            <line x1="0" y1="0" x2="0" y2="8" stroke="rgba(230,150,50,0.3)" stroke-width="2"/>
          </pattern>
          <pattern id="hatch-argb" patternUnits="userSpaceOnUse" width="8" height="8" patternTransform="rotate(45)">
            <line x1="0" y1="0" x2="0" y2="8" stroke="rgba(76,175,80,0.3)" stroke-width="2"/>
          </pattern>
          <!-- Arrow markers -->
          <marker id="arrow-yuv" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="#E53935"/>
          </marker>
          <marker id="arrow-argb" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="#1E88E5"/>
          </marker>
          <marker id="arrow-dpu-out" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="#a78bfa"/>
          </marker>
        </defs>
      </svg>
      <div id="tooltip"></div>
    </div>

    <!-- Side Panel -->
    <div id="side-panel">
      <h3>Display</h3>
      <div class="display-info">
        <span class="display-badge">{{ scenario.display.resolution }}</span>
        <span class="display-badge">{{ scenario.display.width }}×{{ scenario.display.height }}</span>
        <span class="display-badge">{{ scenario.display.fps }}fps</span>
      </div>

      <h3>Clock (MHz)</h3>
      <table class="info-table">
        <tr><th>Parameter</th><th>Value</th></tr>
        <tr><td>Min Pixel Clock</td><td>{{ scenario.clock.min_pixel_clock_mhz }}</td></tr>
        <tr><td>Min AXI Clock</td><td>{{ scenario.clock.min_axi_clock_mhz }}</td></tr>
        <tr><td>ACLK</td><td>{{ scenario.clock.aclk_mhz }}</td></tr>
        <tr><td>MIF Min Freq</td><td>{{ scenario.clock.mif_min_freq_mhz }}</td></tr>
      </table>

      <h3>Legend — Format</h3>
      <div class="legend-item">
        <span class="legend-swatch" style="background:#FFE0B2;"></span>
        <span>YUV (buffer)</span>
      </div>
      <div class="legend-item">
        <span class="legend-swatch" style="background:#C8E6C9;"></span>
        <span>ARGB (buffer)</span>
      </div>
      <div class="legend-item">
        <span class="legend-swatch" style="background:#E53935;"></span>
        <span>YUV edge</span>
      </div>
      <div class="legend-item">
        <span class="legend-swatch" style="background:#1E88E5;"></span>
        <span>ARGB edge</span>
      </div>
      <div style="margin-top:16px;"></div>

      <h3>Legend — Compression</h3>
      <div class="legend-item">
        <span class="legend-swatch hatched" style="background:#FFE0B2;"></span>
        <span>Compressed (dashed edge)</span>
      </div>
      <div class="legend-item">
        <span class="legend-swatch" style="background:#FFE0B2;"></span>
        <span>Uncompressed (solid edge)</span>
      </div>
      <div style="margin-top:16px;"></div>

      <h3>Summary</h3>
      <table class="info-table">
        <tr><td>Total Layers</td><td>{{ scenario.layers | length }}</td></tr>
        <tr><td>Total BW (orig)</td><td>{{ "%.2f" | format(total_bw_orig) }} GB/s</td></tr>
        <tr><td>Total BW (eff)</td><td>{{ "%.2f" | format(total_bw_eff) }} GB/s</td></tr>
        <tr><td>Sources</td><td>{{ sources | join(', ') }}</td></tr>
      </table>
    </div>
  </div>

  <!-- Bottom Layer Table -->
  <div id="bottom-panel">
    <table id="layer-table">
      <thead>
        <tr>
          <th>RDMA</th>
          <th>Layer Name</th>
          <th>Source</th>
          <th>Format</th>
          <th>Category</th>
          <th>Size</th>
          <th>BW (orig)</th>
          <th>BW (comp)</th>
          <th>Compression</th>
        </tr>
      </thead>
      <tbody>
        {% for layer in scenario.layers %}
        <tr data-rdma="{{ layer.rdma_index }}"
            onmouseenter="highlightEdge({{ layer.rdma_index }}, true)"
            onmouseleave="highlightEdge({{ layer.rdma_index }}, false)">
          <td style="font-weight:700; color:#a78bfa;">{{ layer.rdma_index }}</td>
          <td>{{ layer.name }}</td>
          <td>{{ layer.source }}</td>
          <td>{{ layer.format }}</td>
          <td>
            <span class="fmt-badge {% if layer.format_category == 'YUV' %}fmt-yuv{% else %}fmt-argb{% endif %}">
              {{ layer.format_category }}
            </span>
          </td>
          <td>{{ layer.size.width }}×{{ layer.size.height }}</td>
          <td class="bw-val">{{ "%.3f" | format(layer.bw.original_gbps) }}</td>
          <td class="bw-val {% if layer.bw.compressed_gbps is not none %}bw-compressed{% endif %}">
            {% if layer.bw.compressed_gbps is not none %}{{ "%.3f" | format(layer.bw.compressed_gbps) }}{% else %}—{% endif %}
          </td>
          <td>
            <span class="comp-badge comp-{{ layer.compression_type | lower }}">
              {{ layer.compression_type }}
            </span>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<script>
// ============================================================
// Scenario data injected by Jinja2
// ============================================================
const SCENARIO = {{ scenario_json }};

// ============================================================
// Layout constants
// ============================================================
const PADDING = 40;
const SOURCE_W = 140, SOURCE_H_MIN = 60;
const BUF_W = 120, BUF_H = 42;
const DPU_W = 100, DPU_PORT_H = 28, DPU_PAD = 16;
const DISPLAY_W = 130, DISPLAY_H = 100;
const COL_GAP = 100;
const ROW_GAP = 10;

const COLOR = {
  source: { fill: '#2a2a3e', stroke: '#4a4a5e', text: '#e0e0e0' },
  dpu:    { fill: '#2d1f4e', stroke: '#5b3f8e', text: '#d4b8ff' },
  display:{ fill: '#1a2632', stroke: '#3a5a72', text: '#e0e0e0' },
  buf_yuv:  { fill: '#3d2e1a', stroke: '#FFB74D' },
  buf_argb: { fill: '#1a3d1e', stroke: '#81C784' },
  edge_yuv: '#E53935',
  edge_argb: '#1E88E5',
  dpu_out: '#a78bfa',
};

// ============================================================
// Build layout data
// ============================================================
const layers = SCENARIO.layers;
const sourceGroups = {};
layers.forEach(l => {
  if (!sourceGroups[l.source]) sourceGroups[l.source] = [];
  sourceGroups[l.source].push(l);
});
const sourceNames = Object.keys(sourceGroups);

// Compute positions  (left-to-right: Sources → Buffers → DPU → Display)
// Use a fixed minimum slot count so all diagrams render at the same scale
const MIN_VISUAL_SLOTS = 10;
const numPorts = layers.length;
const visualSlots = Math.max(numPorts, MIN_VISUAL_SLOTS);
const dpuH = visualSlots * DPU_PORT_H + DPU_PAD * 2;
const totalBufH = numPorts * (BUF_H + ROW_GAP) - ROW_GAP;
const canvasH = Math.max(dpuH, totalBufH, 300) + PADDING * 2;

// Column X positions
const col = {
  source: PADDING,
  buf:    PADDING + SOURCE_W + COL_GAP,
  dpu:    PADDING + SOURCE_W + COL_GAP + BUF_W + COL_GAP,
  display: PADDING + SOURCE_W + COL_GAP + BUF_W + COL_GAP + DPU_W + COL_GAP,
};
const totalW = col.display + DISPLAY_W + PADDING;

// Source positions — stack vertically, centered
function computeSourcePositions() {
  const positions = {};
  // For each source, figure out which buffers belong to it (for vertical centering)
  let y = PADDING;
  sourceNames.forEach((src, i) => {
    const srcLayers = sourceGroups[src];
    const h = Math.max(SOURCE_H_MIN, srcLayers.length * 30 + 20);
    positions[src] = { x: col.source, y, w: SOURCE_W, h };
    y += h + ROW_GAP * 2;
  });
  // Center block
  const totalSourceH = y - ROW_GAP * 2;
  const offsetY = (canvasH - totalSourceH) / 2;
  Object.values(positions).forEach(p => p.y += offsetY);
  return positions;
}

function computeBufferPositions() {
  const positions = {};
  const startY = (canvasH - totalBufH) / 2;
  // sort by rdma_index
  const sorted = [...layers].sort((a, b) => a.rdma_index - b.rdma_index);
  sorted.forEach((l, i) => {
    positions[l.rdma_index] = {
      x: col.buf, y: startY + i * (BUF_H + ROW_GAP),
      w: BUF_W, h: BUF_H, layer: l
    };
  });
  return positions;
}

const srcPos = computeSourcePositions();
const bufPos = computeBufferPositions();
const dpuPos = { x: col.dpu, y: (canvasH - dpuH) / 2, w: DPU_W, h: dpuH };
const dispPos = { x: col.display, y: (canvasH - DISPLAY_H) / 2, w: DISPLAY_W, h: DISPLAY_H };

// ============================================================
// Render SVG
// ============================================================
const svg = document.getElementById('diagram');
svg.setAttribute('viewBox', `0 0 ${totalW} ${canvasH}`);
svg.setAttribute('width', totalW);
svg.setAttribute('height', canvasH);

function svgEl(tag, attrs = {}) {
  const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
  Object.entries(attrs).forEach(([k, v]) => el.setAttribute(k, v));
  return el;
}

// --- Draw Source blocks ---
sourceNames.forEach(src => {
  const p = srcPos[src];
  const g = svgEl('g', { class: 'node-group' });

  g.appendChild(svgEl('rect', {
    class: 'node-rect',
    x: p.x, y: p.y, width: p.w, height: p.h,
    fill: COLOR.source.fill, stroke: COLOR.source.stroke, 'stroke-width': 1.5
  }));
  g.appendChild(svgEl('text', {
    class: 'node-label',
    x: p.x + p.w / 2, y: p.y + 18,
    fill: COLOR.source.text
  }));
  g.lastChild.textContent = src;

  // Sub-label: layer count
  g.appendChild(svgEl('text', {
    class: 'node-sublabel',
    x: p.x + p.w / 2, y: p.y + 36,
  }));
  g.lastChild.textContent = `${sourceGroups[src].length} layer(s)`;

  svg.appendChild(g);
});

// --- Draw Buffer nodes ---
Object.entries(bufPos).forEach(([rdma, p]) => {
  const l = p.layer;
  const isYUV = l.format_category === 'YUV';
  const isCompressed = l.compression_type !== 'None';
  const bufColor = isYUV ? COLOR.buf_yuv : COLOR.buf_argb;

  const g = svgEl('g', { class: 'node-group', 'data-rdma': rdma });

  // Main rect
  g.appendChild(svgEl('rect', {
    class: 'node-rect',
    x: p.x, y: p.y, width: p.w, height: p.h,
    fill: bufColor.fill, stroke: bufColor.stroke, 'stroke-width': 1.5
  }));

  // Hatching overlay for compressed
  if (isCompressed) {
    g.appendChild(svgEl('rect', {
      class: 'buffer-hatch',
      x: p.x, y: p.y, width: p.w, height: p.h,
      fill: isYUV ? 'url(#hatch-yuv)' : 'url(#hatch-argb)',
      stroke: 'none'
    }));
  }

  // Buffer name
  g.appendChild(svgEl('text', {
    class: 'node-label',
    x: p.x + p.w / 2, y: p.y + p.h / 2 - 6,
    fill: isYUV ? '#FFB74D' : '#81C784',
    'font-size': '11px'
  }));
  g.lastChild.textContent = l.name;

  // Size sub-label
  g.appendChild(svgEl('text', {
    class: 'node-sublabel',
    x: p.x + p.w / 2, y: p.y + p.h / 2 + 10,
    'font-size': '9px',
    fill: '#888'
  }));
  g.lastChild.textContent = `${l.format} ${l.size.width}×${l.size.height}`;

  // Tooltip on hover
  g.addEventListener('mouseenter', (e) => showTooltip(e, l));
  g.addEventListener('mouseleave', hideTooltip);

  svg.appendChild(g);
});

// --- Draw DPU block with RDMA ports ---
(function drawDPU() {
  const g = svgEl('g', { class: 'node-group' });
  const p = dpuPos;

  // Main DPU rect
  g.appendChild(svgEl('rect', {
    class: 'node-rect',
    x: p.x, y: p.y, width: p.w, height: p.h,
    fill: COLOR.dpu.fill, stroke: COLOR.dpu.stroke, 'stroke-width': 2
  }));

  // DPU label
  g.appendChild(svgEl('text', {
    class: 'node-label',
    x: p.x + p.w / 2, y: p.y + 14,
    fill: COLOR.dpu.text, 'font-size': '14px'
  }));
  g.lastChild.textContent = 'DPU';

  // RDMA ports
  const sorted = [...layers].sort((a, b) => a.rdma_index - b.rdma_index);
  sorted.forEach((l, i) => {
    const portY = p.y + DPU_PAD + 16 + i * DPU_PORT_H;
    const portW = p.w - 12;
    const portX = p.x + 6;
    const portH = DPU_PORT_H - 4;

    const isYUV = l.format_category === 'YUV';

    g.appendChild(svgEl('rect', {
      class: 'port-rect',
      x: portX, y: portY, width: portW, height: portH,
      fill: isYUV ? 'rgba(255,183,77,0.12)' : 'rgba(129,199,132,0.12)',
      stroke: isYUV ? 'rgba(255,183,77,0.3)' : 'rgba(129,199,132,0.3)',
      'stroke-width': 1,
      'data-rdma': l.rdma_index
    }));

    g.appendChild(svgEl('text', {
      class: 'port-label',
      x: portX + portW / 2, y: portY + portH / 2,
      fill: '#999'
    }));
    g.lastChild.textContent = `R${l.rdma_index}`;
  });

  svg.appendChild(g);
})();

// --- Draw Display block ---
(function drawDisplay() {
  const g = svgEl('g', { class: 'node-group' });
  const p = dispPos;

  g.appendChild(svgEl('rect', {
    class: 'node-rect',
    x: p.x, y: p.y, width: p.w, height: p.h,
    fill: COLOR.display.fill, stroke: COLOR.display.stroke, 'stroke-width': 1.5
  }));

  g.appendChild(svgEl('text', {
    class: 'node-label',
    x: p.x + p.w / 2, y: p.y + p.h / 2 - 16,
    fill: COLOR.display.text, 'font-size': '14px'
  }));
  g.lastChild.textContent = 'Display';

  g.appendChild(svgEl('text', {
    class: 'node-sublabel',
    x: p.x + p.w / 2, y: p.y + p.h / 2 + 4,
    fill: '#aaa', 'font-size': '12px'
  }));
  g.lastChild.textContent = SCENARIO.display.resolution;

  g.appendChild(svgEl('text', {
    class: 'node-sublabel',
    x: p.x + p.w / 2, y: p.y + p.h / 2 + 22,
    fill: '#888', 'font-size': '10px'
  }));
  g.lastChild.textContent = `${SCENARIO.display.width}×${SCENARIO.display.height} ${SCENARIO.display.fps}fps`;

  svg.appendChild(g);
})();

// --- Draw Edges ---
function drawEdges() {
  const sorted = [...layers].sort((a, b) => a.rdma_index - b.rdma_index);

  sorted.forEach((l, i) => {
    const isYUV = l.format_category === 'YUV';
    const isCompressed = l.compression_type !== 'None';
    const edgeColor = isYUV ? COLOR.edge_yuv : COLOR.edge_argb;
    const markerId = isYUV ? 'arrow-yuv' : 'arrow-argb';
    const dashArray = isCompressed ? '6,4' : 'none';

    const bp = bufPos[l.rdma_index];
    const bufCenterY = bp.y + bp.h / 2;

    // 1) Source → Buffer
    const sp = srcPos[l.source];
    const srcRight = sp.x + sp.w;
    const srcCenterY = sp.y + sp.h / 2;

    const path1 = svgEl('path', {
      class: 'edge-path',
      d: `M${srcRight},${srcCenterY} C${srcRight + COL_GAP * 0.5},${srcCenterY} ${bp.x - COL_GAP * 0.5},${bufCenterY} ${bp.x},${bufCenterY}`,
      fill: 'none', stroke: edgeColor, 'stroke-width': 1.5,
      'stroke-dasharray': dashArray,
      'marker-end': `url(#${markerId})`,
      'data-rdma': l.rdma_index
    });
    svg.appendChild(path1);

    // 2) Buffer → DPU port
    const portY = dpuPos.y + DPU_PAD + 16 + i * DPU_PORT_H + (DPU_PORT_H - 4) / 2;

    const path2 = svgEl('path', {
      class: 'edge-path',
      d: `M${bp.x + bp.w},${bufCenterY} C${bp.x + bp.w + COL_GAP * 0.5},${bufCenterY} ${dpuPos.x - COL_GAP * 0.5},${portY} ${dpuPos.x},${portY}`,
      fill: 'none', stroke: edgeColor, 'stroke-width': 1.5,
      'stroke-dasharray': dashArray,
      'marker-end': `url(#${markerId})`,
      'data-rdma': l.rdma_index
    });
    svg.appendChild(path2);

    // Edge label on buffer→DPU segment — only for compressed buffers
    if (isCompressed) {
      const labelX = (bp.x + bp.w + dpuPos.x) / 2;
      const labelY = (bufCenterY + portY) / 2;

      const lblBg = svgEl('rect', {
        class: 'edge-label-bg',
        x: labelX - 22, y: labelY - 8, width: 44, height: 16
      });
      svg.appendChild(lblBg);

      const lblTxt = svgEl('text', {
        class: 'edge-label-text',
        x: labelX, y: labelY,
        fill: edgeColor
      });
      lblTxt.textContent = l.compression_type;
      svg.appendChild(lblTxt);
    }
  });

  // 3) DPU → Display (single composite edge)
  const dpuRight = dpuPos.x + dpuPos.w;
  const dpuCenterY = dpuPos.y + dpuPos.h / 2;
  const dispCenterY = dispPos.y + dispPos.h / 2;

  const path3 = svgEl('path', {
    class: 'edge-path',
    d: `M${dpuRight},${dpuCenterY} C${dpuRight + COL_GAP * 0.4},${dpuCenterY} ${dispPos.x - COL_GAP * 0.4},${dispCenterY} ${dispPos.x},${dispCenterY}`,
    fill: 'none', stroke: COLOR.dpu_out, 'stroke-width': 2.5,
    'marker-end': 'url(#arrow-dpu-out)'
  });
  svg.appendChild(path3);
}
drawEdges();

// ============================================================
// Tooltip
// ============================================================
function showTooltip(e, layer) {
  const tip = document.getElementById('tooltip');
  const bwText = layer.bw.compressed_gbps != null
    ? `${layer.bw.original_gbps} → ${layer.bw.compressed_gbps} GB/s`
    : `${layer.bw.original_gbps} GB/s`;

  tip.innerHTML = `
    <div class="tip-title">${layer.name}</div>
    <div class="tip-row"><span class="tip-key">Source</span><span class="tip-val">${layer.source}</span></div>
    <div class="tip-row"><span class="tip-key">Format</span><span class="tip-val">${layer.format} (${layer.format_category})</span></div>
    <div class="tip-row"><span class="tip-key">Size</span><span class="tip-val">${layer.size.width}×${layer.size.height}</span></div>
    <div class="tip-row"><span class="tip-key">BW</span><span class="tip-val">${bwText}</span></div>
    <div class="tip-row"><span class="tip-key">Compression</span><span class="tip-val">${layer.compression_type}</span></div>
    <div class="tip-row"><span class="tip-key">RDMA</span><span class="tip-val">${layer.rdma_index}</span></div>
  `;
  tip.style.display = 'block';

  // Position near cursor but inside viewport
  const canvas = document.getElementById('canvas');
  const rect = canvas.getBoundingClientRect();
  let left = e.clientX - rect.left + 12;
  let top = e.clientY - rect.top + 12;
  if (left + 280 > rect.width) left -= 300;
  if (top + 200 > rect.height) top -= 220;
  tip.style.left = left + 'px';
  tip.style.top = top + 'px';
}

function hideTooltip() {
  document.getElementById('tooltip').style.display = 'none';
}

// ============================================================
// Table ↔ Canvas highlight
// ============================================================
function highlightEdge(rdma, on) {
  // Highlight edges
  document.querySelectorAll(`.edge-path[data-rdma="${rdma}"]`).forEach(el => {
    el.style.strokeWidth = on ? '4' : '';
    el.style.filter = on ? 'drop-shadow(0 0 4px currentColor)' : '';
  });
  // Highlight buffer node
  document.querySelectorAll(`.node-group[data-rdma="${rdma}"] .node-rect`).forEach(el => {
    el.style.filter = on ? 'drop-shadow(0 0 6px rgba(167,139,250,0.6))' : '';
  });
  // Highlight DPU port
  document.querySelectorAll(`.port-rect[data-rdma="${rdma}"]`).forEach(el => {
    el.style.filter = on ? 'drop-shadow(0 0 4px rgba(167,139,250,0.6))' : '';
    el.style.fillOpacity = on ? '0.4' : '';
  });
}

// ============================================================
// Canvas resize — fit SVG to container
// ============================================================
function resizeCanvas() {
  const container = document.getElementById('canvas');
  const svgEl = document.getElementById('diagram');
  const cw = container.clientWidth;
  const ch = container.clientHeight;

  // Maintain aspect ratio, fit within container
  const scale = Math.min(cw / totalW, ch / canvasH);
  svgEl.style.width = totalW * scale + 'px';
  svgEl.style.height = canvasH * scale + 'px';
}
window.addEventListener('resize', resizeCanvas);
resizeCanvas();
</script>
</body>
</html>
